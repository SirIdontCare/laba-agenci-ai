# ============================================
# 🔑 Zmienne srodowiskowe — KOPIA agenta (Grupa Zaawansowana)
# ============================================
# Ten plik to WZOR. Skopiuj go do swojej kopii agenta jako .env.local
# i podmien opisowe placeholdery na prawdziwe wartosci.
#
#   Windows (PowerShell):  Copy-Item .env.local.example .env.local
#   Mac / Linux:           cp .env.local.example .env.local
#
# ⚠️ .env.local NIGDY nie trafia do repo (jest w .gitignore).
# ⚠️ To jest KOPIA agenta — wpisz tu klucze NOWEJ bazy, nie kursowej!
# ============================================


# --- Model AI (Gemini) ------------------------------------
# Ten sam klucz, ktorego uzywasz w kursie — nic nowego nie zakladasz.
# Pobierz / podejrzyj: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=TU_WKLEJ_SWOJ_KLUCZ_Z_AI_STUDIO


# --- Baza danych (NOWY, osobny projekt Supabase) ----------
# UWAGA: to musza byc dane Twojego NOWEGO projektu z Modulu 0,
# a NIE tego, ktorego uzywasz na zwyklych zajeciach.
# Znajdziesz je: Supabase -> nowy projekt -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://TU_WKLEJ_ID_NOWEGO_PROJEKTU.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_WKLEJ_ANON_KEY_Z_NOWEGO_PROJEKTU

# Odkomentuj tylko, jesli Twoj agent zapisuje dane po stronie serwera
# (sprawdz, czy ta zmienna wystepuje w Twoim starym .env.local):
# SUPABASE_SERVICE_ROLE_KEY=TU_WKLEJ_SERVICE_ROLE_KEY_Z_NOWEGO_PROJEKTU


# --- Wyszukiwanie Google (PLATNE — domyslnie wylaczone) ---
# Odkomentuj TYLKO na czas testow, a po testach usun te linie.
# Zostawiona na stale potrafi zjesc caly limit.
# ENABLE_SEARCH_GROUNDING=true
